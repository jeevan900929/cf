{
  "name": "cf-boilerplate",
  "private": true,
  "type": "module",
  "workspaces": [
    "infra/pulumi"
  ],
  "scripts": {
    "dev": "wrangler pages dev pages --port 8788 -- wrangler dev --port 8787",
    "check": "npm run test && npm run typecheck",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "types": "wrangler types",
    "deploy": "node scripts/deploy-worker.mjs && node scripts/deploy-pages.mjs",
    "deploy:worker": "node scripts/deploy-worker.mjs",
    "deploy:pages": "node scripts/deploy-pages.mjs"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.2",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.75.0"
  }
}
